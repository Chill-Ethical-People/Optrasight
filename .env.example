# =====================================================================
# OptraSight — environment configuration
# Copy to `.env` and edit.
# =====================================================================

# --------------------- Runtime ---------------------
# `production` switches off Vite dev middleware, serves the built bundle,
# and enables strict mode (see OPTRASIGHT_STRICT below).
NODE_ENV=production

# HTTP port.
PORT=5001

# --------------------- Production-strict mode ---------------------
# When 1, every AI / OSINT path refuses to silently fall back to mock
# output and surfaces HTTP 409 / 502 with a real provider error.
# When 0, mock fallbacks fire when no provider is configured.
# Defaults to 1 when NODE_ENV=production, 0 otherwise. Override explicitly:
OPTRASIGHT_STRICT=1

# --------------------- Live AI master switch ---------------------
# When 0, every live AI call is short-circuited regardless of per-provider
# keys. Useful for local development without API quota. Default 1.
OPTRASIGHT_AI_LIVE=1

# --------------------- Hosting hints (optional) ---------------------
# Reserved for future multi-host orchestration. Leave unset.
# HOSTING_MODE=

# =====================================================================
# AI PROVIDER KEYS ARE NOT READ FROM ENV
# ---------------------------------------------------------------------
# OptraSight stores AI provider keys in the local secret database and
# references them from the ai_providers table. Configure them at /#/ai-setup
# after first login. Keys are never bundled in the public seed data.
# =====================================================================
